# Copy this file to .env and fill in your values for local development.
# NEVER commit .env to git.

DATABASE_URL=jdbc:postgresql://localhost:5432/orthopro
DB_USERNAME=postgres
DB_PASSWORD=yourpassword

UPLOAD_DIR=uploads
DOCS_DIR=uploads/docs
TESTS_DIR=uploads/tests
MODELS_DIR=uploads/models
QRCODE_DIR=uploads/qr-codes

QRCODE_SALT=MySecretSalt123

# Comma-separated list of frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
